{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Cyclestone",
            "type": "shell",
            "command": "go",
            "args": [
                "build",
                "-o",
                "${workspaceFolder}/cyclestone",
                "${workspaceFolder}/cmd/cyclestone/main.go"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$go"
            ]
        }
    ]
}
